{
  "project": "agent-evals-frontend",
  "purpose": "React+TS frontend for Langfuse-backed agent evaluations",
  "verified": {
    "tests": 149,
    "typecheck": "clean",
    "build": "passing"
  },
  "start_here": "START_HERE.md",
  "build_instructions": "docs/BUILD_PLAN.md",
  "phases": [
    {
      "phase": 0,
      "name": "Scaffold",
      "gate": "npm run build"
    },
    {
      "phase": 1,
      "name": "Domain layer",
      "gate": "npm test -- domain",
      "expect_tests": 74
    },
    {
      "phase": 2,
      "name": "API layer",
      "gate": "npm test -- api",
      "expect_tests": 29
    },
    {
      "phase": 3,
      "name": "Hooks",
      "gate": "npm run typecheck"
    },
    {
      "phase": 4,
      "name": "UI",
      "gate": "npm run build"
    },
    {
      "phase": 5,
      "name": "Tests",
      "gate": "npm test",
      "expect_tests": 149
    }
  ],
  "layer_rule": "domain/ imports nothing from api/, hooks/, or routes/",
  "sole_owners": {
    "langfuse_json_parsing": "src/domain/model.ts::toQuestion",
    "results_join": "src/api/runs.ts::getRunResults"
  },
  "known_traps": [
    {
      "id": 1,
      "symptom": "TS1294 on constructor",
      "cause": "TypeScript parameter properties are forbidden by erasableSyntaxOnly",
      "fix": "Use explicit fields",
      "step": "0.4"
    },
    {
      "id": 2,
      "symptom": "UI shows literal {\"criteria\":\"\"}",
      "cause": "readText missing the empty-string branch",
      "fix": "Return '' for a wanted key holding an empty string",
      "step": "1.3"
    },
    {
      "id": 3,
      "symptom": "Drift detection never fires",
      "cause": "contentHash lacks a separator",
      "fix": "Hash prompt + \\u0000 + criteria",
      "step": "1.3"
    },
    {
      "id": 4,
      "symptom": "Broken judge shows as agent failure",
      "cause": "scoreToOutcome returns 'failed' for missing score",
      "fix": "Return 'error' and exclude from pass rate",
      "step": "1.3"
    },
    {
      "id": 5,
      "symptom": "Silent 'run not found'",
      "cause": "RunsApi.list rejects bare-array responses",
      "fix": "Accept both envelope and array",
      "step": "2.3"
    },
    {
      "id": 6,
      "symptom": "Suite count off by one",
      "cause": "Archived questions counted",
      "fix": "Skip archived in deriveSuites",
      "step": "1.4"
    },
    {
      "id": 7,
      "symptom": "Suite vanishes when emptied",
      "cause": "knownSuites not passed",
      "fix": "Persist names, include at count 0",
      "step": "1.4"
    },
    {
      "id": 8,
      "symptom": "Unrelated failures merged",
      "cause": "Confidence floor missing",
      "fix": "Return singletons below 0.45",
      "step": "1.5"
    },
    {
      "id": 9,
      "symptom": "Results page fails on one bad trace",
      "cause": "Not using Promise.allSettled",
      "fix": "Settle per trace",
      "step": "2.3"
    },
    {
      "id": 10,
      "symptom": "Polling never stops",
      "cause": "refetchInterval not returning false",
      "fix": "Return false when done>=total",
      "step": "3"
    },
    {
      "id": 11,
      "symptom": "Dead backend takes 9 attempts",
      "cause": "Both ApiClient and QueryClient retry",
      "fix": "retry:false on QueryClient",
      "step": "4.8"
    },
    {
      "id": 12,
      "symptom": "Criteria blanked after suite edit",
      "cause": "Membership write dropped other fields",
      "fix": "Read-modify-write preserving name/criteria/tags",
      "step": "2.2"
    }
  ],
  "invariants": [
    "No copy/duplicate affordance anywhere (enforced by test)",
    "archive uses PATCH status:ARCHIVED, never DELETE",
    "Errored results excluded from pass-rate denominator",
    "Every route handles loading, error, empty, populated",
    "Every interactive control has an accessible name"
  ],
